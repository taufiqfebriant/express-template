{
  "name": "express-template",
  "description": "Monorepo template for Express backends, Vue frontends, shared JS modules, schemas, and deployment tooling.",
  "version": "0.0.8",
  "private": true,
  "type": "module",
  "author": "aaronjxz@gmail.com",
  "license": "MIT",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/es-labs/express-template"
  },
  "bugs": {
    "url": "https://github.com/es-labs/express-template/issues"
  },
  "homepage": "https://github.com/es-labs/express-template#readme",
  "keywords": [
    "nodejs",
    "express"
  ],
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "scripts": {
    "git:hash": "git rev-parse --verify --short HEAD",
    "git:branch": "git rev-parse --abbrev-ref HEAD",
    "lint": "biome lint apps webs scripts common/iso common/node common/schemas common/web common/vue",
    "lint:fix": "biome lint --only=useTemplate --write --unsafe common/node",
    "format": "biome format --write apps webs scripts common/iso common/node common/schemas common/web common/vue",
    "check": "biome check --write apps webs scripts common/iso common/node common/schemas common/web common/vue",
    "ci": "biome ci .",
    "docs:generate": "node scripts/generate-openapi.js",
    "docs:validate-swagger": "swagger-cli validate docs/openapi/openapi.merged.yaml",
    "docs:validate": "npx redocly lint docs/openapi/openapi.merged.yaml",
    "docs:make-html": "npx @redocly/cli build-docs docs/openapi/openapi.merged.yaml --output index.html",
    "prepare": "git config core.hooksPath .githooks || echo 'Can not set git hooks'",
    "test:workspace": "npm run test --workspace=apps/app-sample",
    "test:workspaces": "npm run test --workspaces",
    "test:cover-only": "node --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=lcov.info --test __tests__/**/*.spec.js",
    "test:e2e": "start-server-and-test start http://localhost:8080 test",
    "release:auth": "semantic-release -e ./release/auth-service.release.config.cjs",
    "update-commit-hash": "git rev-parse --verify --short HEAD > commit-hash"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@playwright/test": "^1.59.1",
    "@redocly/cli": "^2.25.4",
    "@vitejs/plugin-vue": "^6.0.5",
    "msw": "^2.13.1",
    "node-mocks-http": "^1.17.2",
    "start-server-and-test": "^3.0.0",
    "vite": "^8.0.7"
  },
  "workspaces": [
    "apps/*",
    "common/*",
    "webs/*"
  ]
}
