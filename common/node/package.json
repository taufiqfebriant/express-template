{
  "name": "@common/node",
  "version": "0.0.2",
  "author": "Aaron Gong",
  "license": "MIT",
  "description": "Shareable Node Runtime JS library using ES modules",
  "keywords": [
    "javscript",
    "module"
  ],
  "homepage": "https://github.com/es-labs/express-template#readme",
  "bugs": {
    "url": "https://github.com/es-labs/express-template/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/es-labs/express-template.git"
  },
  "type": "module",
  "exports": {
    ".": "./index.js",
    "./auth": "./auth/index.js",
    "./express/controller/auth": "./express/controller/auth/index.js",
    "./node/auth": "./node/auth/index.js",
    "./logger": "./logger/index.js",
    "./services": "./services/index.js",
    "./*": "./*.js",
    "./**/*": "./**/*.js"
  },
  "main": "index.js",
  "scripts": {
    "test": "node --experimental-test-coverage --test-reporter=spec --test **/__tests__/*.test.js",
    "cover": "node --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=lcov.info --test __tests__/**/*.spec.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1026.0",
    "@node-saml/node-saml": "^5.1.0",
    "@scalar/express-api-reference": "^0.9.6",
    "ali-oss": "^6.23.0",
    "bcryptjs": "^3.0.3",
    "connect-history-api-fallback": "^2.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "keyv": "^5.6.0",
    "knex": "^3.2.9",
    "multer": "^2.1.1",
    "mysql": "^2.18.1",
    "otplib": "^13.4.0",
    "path-to-regexp": "^8.4.2",
    "pg": "^8.20.0",
    "serve-index": "^1.9.2",
    "sqlite3": "^5.1.7",
    "web-push": "^3.6.7",
    "ws": "^8.20.0",
    "zod": "^4.3.6",
    "zod-openapi": "^5.4.6"
  }
}
