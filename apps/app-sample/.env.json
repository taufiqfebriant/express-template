{
  "KNEXFILE": {
    "client": "sqlite3",
    "connection": {
      "filename": "./dev.sqlite3"
    },
    "useNullAsDefault": true
  },
  "KEYV_CACHE": {},
  "SERVICES_CONFIG": [
    {
      "name": "knex1",
      "type": "knex",
      "options": "KNEXFILE"
    },
    {
      "name": "keyv",
      "type": "keyv",
      "options": "KEYV_CACHE"
    },
    {
      "name": "ws",
      "type": "ws",
      "options": "WS_OPTIONS"
    }
  ],
  "CORS_OPTIONS": {
    "methods": "GET,HEAD,PUT,PATCH,POST,DELETE,OPTIONS",
    "preflightContinue": false,
    "optionsSuccessStatus": 204,
    "credentials": true,
    "origin": [
      "http://127.0.0.1:8080",
      "https://127.0.0.1:8080"
    ]
  },
  "RES_HEADERS_ADD": {
    "Access-Control-Allow-Origin": "*"
  },
  "WEB_STATIC": [
    {
      "folder": "../../node_modules/@common/web",
      "url": "/esm"
    },
    {
      "folder": "public/openapi",
      "url": "/openapi",
      "options": {
        "icons": true,
        "list": true
      }
    },
    {
      "folder": "public/vue-nobundler",
      "url": "/native",
      "options": {
        "extensions": [
          "html"
        ],
        "index": false
      }
    },
    {
      "folder": "public/demo-express",
      "url": "/"
    }
  ],
  "UPLOAD_STATIC": [
    {
      "url": "/uploads",
      "options": {
        "limits": {
          "files": 2,
          "fileSize": 10000000
        }
      },
      "list": true,
      "listOptions": {
        "icons": true
      }
    }
  ]
}