{
  "name": "@express-template/app-sample",
  "description": "sample application/service",
  "version": "0.0.6",
  "private": true,
  "type": "module",
  "author": "aaronjxz@gmail.com",
  "license": "MIT",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/es-labs/express-template"
  },
  "bugs": {
    "url": "https://github.com/es-labs/express-template/issues"
  },
  "homepage": "https://github.com/es-labs/express-template#readme",
  "keywords": [
    "nodejs",
    "express"
  ],
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "start": "node --watch --watch-preserve-output --trace-warnings src/index.js",
    "test:unit": "node --test-reporter=spec --experimental-test-coverage --test --test-only ./src/**/__tests__/unit/*.test.js",
    "test:integration": "node --test-reporter=spec --experimental-test-coverage --test --test-only ./src/**/__tests__/integration/*.test.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:e2e": "start-server-and-test start http://localhost:8080 test"
  },
  "dependencies": {
    "@common/iso": "file:../../common/iso",
    "@common/node": "file:../../common/node",
    "@json2csv/plainjs": "^7.0.6",
    "csv-parse": "^6.2.1",
    "fido2-lib": "^3.5.9",
    "pdfkit": "^0.18.0",
    "selfsigned": "^5.5.0"
  }
}
